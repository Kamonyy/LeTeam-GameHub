PORT=3001
# Local dev only — do not expose this server to the public internet.
# For any host reachable beyond your LAN, use NODE_ENV=production and DISABLE_DEV_BOTS=true.
NODE_ENV=development
# Lobby test bots — all games (development) or Mafia-only on production:
# ALLOW_DEV_BOTS=true
# ALLOW_MAFIA_DEV_BOTS=true
ALLOW_DEV_BOTS=true
# Listen on all interfaces for LAN testing (phones, other PCs). Keep LAN-only.
HOST=0.0.0.0
# Extra origins. Wildcard (*) is rejected when credentials are enabled.
CLIENT_URL=http://localhost:3000,http://127.0.0.1:3000,https://gamehub.mohamed-hussein.net
# Allow http://192.168.x.x:3000 CORS without NODE_ENV=development (LAN dev only).
# DEV_LAN_CORS=true
